# ─────────────────────────────────────────────────────────────────────────────
# YouTube Clipping Operation — credentials & config
# Copy to `.env` and fill in. NOTHING here is required to run `ycp demo` or
# `ycp source` (those use yt-dlp, no keys). Keys only unlock speed + full metrics.
# ─────────────────────────────────────────────────────────────────────────────

# --- YouTube Data API (OPTIONAL) ---------------------------------------------
# Speeds up sourcing. Without it, sourcing falls back to yt-dlp (no key, slower).
# Get one: https://console.cloud.google.com/  -> enable "YouTube Data API v3"
YOUTUBE_API_KEY=

# --- YouTube Analytics API (OPTIONAL, for FULL metrics) ----------------------
# Needed only for retention %, RPM, and ad revenue on YOUR owned channels.
# Requires OAuth per channel. Public view counts work today without this.
YT_OAUTH_CLIENT_SECRET_JSON=   # path to client_secret.json
YT_OAUTH_TOKEN_DIR=./data/oauth  # per-channel tokens cached here

# --- Whop (OPTIONAL) ----------------------------------------------------------
# Payout capture. Reliable path is CSV export from the Whop dashboard
# (`ycp capture --whop-csv path.csv`). API key is for future automation.
WHOP_API_KEY=

# --- Slack QC board (REQUIRED only for `ycp qc`) ------------------------------
# Create an app at https://api.slack.com/apps (Socket Mode ON).
# Scopes: chat:write, reactions:read, channels:history, groups:history
SLACK_BOT_TOKEN=        # xoxb-...
SLACK_APP_TOKEN=        # xapp-...  (Socket Mode)
SLACK_QC_CHANNEL=       # e.g. C0123ABCD  (the #clip-qc channel id)
